# Copy this file to .env and fill in values for local development.
# On Railway/Render, set these as environment variables in the dashboard.

# Your Vercel frontend URL — used for CORS.
# Set to * to allow all origins (less secure).
CORS_ORIGIN=https://your-vercel-site.vercel.app

# Optional: custom path for the SQLite database file.
# Default: deborasaurus.db in the same folder as main.py
# On Render with a Disk mounted at /data, use:
# DB_PATH=/data/deborasaurus.db
DB_PATH=deborasaurus.db
